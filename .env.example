# MomoParse Environment Variables
# Copy this file to .env and fill in values

# API settings
APP_ENV=development         # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database (Week 3)
DATABASE_URL=postgresql://user:password@localhost:5432/momoparse

# Redis (Week 3)
REDIS_URL=redis://localhost:6379

# Auth (Week 3)
SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# Monitoring (Week 4)
SENTRY_DSN=
